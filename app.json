{
  "expo": {
    "name": "Waylo",
    "slug": "waylo",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F7F8FA"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.saikittu332.waylo",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Waylo uses your location to start routes from your current position."
      }
    },
    "android": {
      "package": "com.saikittu332.waylo",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Waylo uses your location to start routes from your current position."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@rnmapbox/maps",
      "expo-font",
      "./plugins/with-ios-modular-headers"
    ],
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "ceaf89bf-1fcf-409c-aed9-36af5ade60db"
      }
    }
  }
}
